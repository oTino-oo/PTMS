@page
@model PTMS.Pages.PT.SessionPages.CreateModel

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f4f6f9;
    }

    h1 {
        text-align: center;
    }

    .form-card {
        max-width: 600px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 12px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        display: block;
        margin-bottom: 6px;
    }

    input, select {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    .btn {
        width: 100%;
        padding: 12px;
        background: #2d6cdf;
        color: white;
        border: none;
        border-radius: 8px;
    }
</style>

<h1>Create Session</h1>

<div class="form-card">

    <form method="post">

        <div class="form-group">
            <label>Client</label>
            <select asp-for="Session.ClientId">
                <option value="">-- Select Client --</option>
                @foreach (var c in Model.Clients)
                {
                    <option value="@c.Id">@c.UserName</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Session.SessionDate"></label>
            <input asp-for="Session.SessionDate" type="datetime-local" />
        </div>

        <div class="form-group">
            <label asp-for="Session.Description"></label>
            <input asp-for="Session.Description" />
        </div>

        <div class="form-group">
            <label asp-for="Session.Price"></label>
            <input asp-for="Session.Price" />
        </div>

        <div class="form-group">
            <label asp-for="Session.TargetValue"></label>
            <input asp-for="Session.TargetValue" type="number" step="0.1" />
        </div>

        <button type="submit" class="btn">Create</button>

    </form>

</div>