@page
@model PTMS.Pages.Client.BookModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Client")]

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f4f6f9;
        margin: 0;
        padding: 0;
    }

    h1 {
        text-align: center;
        margin-top: 20px;
    }

    .booking-card {
        max-width: 600px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    .trainer-info {
        text-align: center;
        margin-bottom: 20px;
        font-size: 18px;
        color: #2d6cdf;
        font-weight: bold;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }

    input, textarea {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

    textarea {
        resize: none;
        height: 100px;
    }

    .btn-submit {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #28a745;
        color: white;
        font-weight: bold;
        cursor: pointer;
        margin-top: 10px;
        transition: 0.2s;
    }

        .btn-submit:hover {
            background: #1f7d34;
        }

    .error-summary {
        max-width: 600px;
        margin: 10px auto;
        color: red;
        font-size: 14px;
    }
</style>

<h1>Booking Form</h1>

<div class="booking-card">

    <div class="trainer-info">
        Booking with: @Model.TrainerName
    </div>

    <div asp-validation-summary="All" class="error-summary"></div>

    <form method="post">

        <input type="hidden" asp-for="TrainerId" />

        <div class="form-group">
            <label>Age</label>
            <input asp-for="Age" />
        </div>

        <div class="form-group">
            <label>Current Weight</label>
            <input asp-for="CurrentWeight" />
        </div>

        <div class="form-group">
            <label>Target Weight</label>
            <input asp-for="TargetWeight" />
        </div>

        <div class="form-group">
            <label>Experience</label>
            <textarea asp-for="Experience"></textarea>
        </div>

        <button type="submit" class="btn-submit">Send Request</button>

    </form>

</div>