@page
@model PTMS.Pages.Admin.DashboardModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f4f6f9;
        margin: 0;
        padding: 0;
    }

    h1 {
        text-align: center;
        margin-top: 20px;
    }

    .container {
        max-width: 1100px;
        margin: auto;
        padding: 20px;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }

    .admin-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        transition: 0.2s;
        text-align: center;
    }

        .admin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.12);
        }

        .admin-card h5 {
            margin-bottom: 10px;
            color: #2d6cdf;
        }

        .admin-card p {
            color: #666;
            font-size: 14px;
        }

    a {
        text-decoration: none;
    }
</style>

<h1>Admin Dashboard</h1>

<div class="container">

    <div class="admin-grid">

        <a asp-page="/Admin/ClientPages/Index">
            <div class="admin-card">
                <h5>Manage Clients</h5>
                <p>Create, edit, and delete clients</p>
            </div>
        </a>

        <a asp-page="/Admin/TrainerPages/Index">
            <div class="admin-card">
                <h5>Manage Trainers</h5>
                <p>Create, edit, and delete trainers</p>
            </div>
        </a>

        <a asp-page="/Admin/SessionPages/Index">
            <div class="admin-card">
                <h5>Manage Sessions</h5>
                <p>Create, edit, and delete sessions</p>
            </div>
        </a>

    </div>

</div>