@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-wrapper">

    <div class="login-card">

        <h1 class="text-center mb-3">Welcome back</h1>
        <p class="text-center text-muted mb-4">Log in to continue</p>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control"
                       autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control"
                       autocomplete="current-password" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    Remember me
                </label>
            </div>

            <button id="login-submit" type="submit"
                    class="btn btn-primary w-100 btn-lg">
                Log in
            </button>

            <div class="login-links mt-3">
                <a asp-page="./ForgotPassword">Forgot password?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create account</a>
                <a asp-page="./ResendEmailConfirmation">Resend confirmation</a>
            </div>

        </form>

    </div>

</div>